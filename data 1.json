if len(sys.argv) < 2:
    print("Usage: python3 add_lieux.py data.json")
    sys.exit(1)

src = sys.argv[1]
if not os.path.exists(src):
    print(f"Fichier introuvable : {src}")
    sys.exit(1)

with open(src, encoding='utf-8') as f:
    data = json.load(f)

added = 0
for ev in data['events']:
    eid = ev.get('id')
    if eid in LIEUX and not ev.get('lieu'):
        ev['lieu'] = LIEUX[eid]
        added += 1

out = src.replace('.json', '_with_lieux.json')
with open(out, 'w', encoding='utf-8') as f:
    json.dump(data, f, ensure_ascii=False, indent=2)

print(f"✅ {added} lieux ajoutés")
print(f"✅ Fichier créé : {out}")
print(f"   → Renommez-le en data.json et uploadez-le sur GitHub")
